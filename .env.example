# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://cptyelmjepgwrerjdkyo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 32+ char random secret used to AES-256-GCM encrypt user Gemini keys at rest.
# Generate with: openssl rand -hex 32
APP_ENCRYPTION_SECRET=change-me-to-a-long-random-secret

# Optional model overrides (defaults shown)
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# OPENAI_TEXT_MODEL=gpt-4o-mini
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_QUALITY=low

# Clip Finder video download relay (cobalt). Defaults to community instances
# (best-effort). For reliable downloads, self-host cobalt and set your own:
# COBALT_INSTANCE=https://your-cobalt-instance.example.com
# COBALT_API_KEY=only-if-your-instance-requires-one
